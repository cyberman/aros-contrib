STATUS: Connecting to %s (%s)
;
MSG_STATUS_CONNECTED_TO (//)
STATUS: Connected to %s
;
MSG_STATUS_CONNECT_FAILED (//)
STATUS: Connection failed, error: '%s'
;
MSG_STATUS_LISTENING (//)
STATUS: Listening on port %d
;
MSG_STATUS_LISTEN_FAILED (//)
STATUS: failed listening on port %d
;
MSG_STATUS_DISCONNECTED (//)
STATUS: Disconnected
;
MSG_STATUS_TRANSFER_ABORTED (//)
STATUS: Transfer aborted by user
;
