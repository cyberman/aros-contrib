STATUS: Connected to server's data port %d
;
MSG_STATUS_UNABLE_ACCEPT (//)
STATUS: Unable to accept an incoming connection on port %d
;
MSG_STATUS_ACCEPTED (//)
STATUS: Accepted an incoming connection on port %d
;
MSG_STATUS_LISTEN_TIMEOUT (//)
STATUS: No connection happened in a timely fashion, closed listen socket
;
MSG_STATUS_ALREADY_CONNECTING (//)
STATUS: Already trying to connect
;
MSG_STATUS_ABORTED (//)
STATUS: Connection aborted
;
MSG_STATUS_NOTHING_TO_ABORT (//)
STATUS: Nothing to abort
;
MSG_STATUS_REFRESHED_LOCAL (//)
STATUS: Refreshed local view
;
MSG_STATUS_TRANSFER_WRITE_ERR (//)
STATUS: Transfer failed, '%d' error during file write
;
